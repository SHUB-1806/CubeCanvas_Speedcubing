def input_marks(a):
    a = []
    for i in range(10):
        j = int(input)
        a.append(j)
    return a

def average(a):
    sum = 0
    for i in a:
        sum += i
    return sum/len(a)

def highest(a):
    maxi = 0
    for i in a:
        maxi = max(maxi, i)
    return maxi

def lowest(a):
    lowe = float('inf')
    for i in a:
        lowe = min(lowe, i)
    return lowe

def no_above_avg(a):
    count = 0
    avg = average(a)
    for i in a:
        if i > avg:
            count+=1
    return count    

def grades(a):
    b = []
    for i in a:
        if i >= 90:
            b.append("A")
        elif i >= 75:
            b.append("B")
        elif i >= 60:
            b.append("C")
        else:
            b.append("D")
    return b

def gradedisplay(a):
    b = grades(a)
    c = {
        'A': 0,
        'B': 0,
        'C': 0,
        'D': 0
    }
    for i in b:
        c[i]+=1
    print (c)

a = input_marks()
print("Highest Marks:", highest(a))
print("Lowest Marks:", highest(a))
print("Averag Marks:", lowest(a))
print("No. of students scoring above avg are:", no_above_avg(a))
gradedisplay(a)